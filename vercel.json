{
  "version": 2,
  "builds": [
    {
      "src": "ecommerce/backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "ecommerce/frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/ecommerce/backend/server.js"
    },
    {
      "source": "/static/(.*)",
      "destination": "/ecommerce/frontend/static/$1"
    },
    {
      "source": "/(favicon\\.ico|manifest\\.json|logo192\\.png|logo512\\.png|robots\\.txt)",
      "destination": "/ecommerce/frontend/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/ecommerce/frontend/index.html"
    }
  ]
}
